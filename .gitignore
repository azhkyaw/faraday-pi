# Python
__pycache__/
*.py[cod]
.venv/
venv/
env/
*.egg-info/
.pytest_cache/
.ruff_cache/
.mypy_cache/

# Models & private data — large / not for version control
models/
*.gguf
*.bin
data/
/corpus/
*.sqlite
*.sqlite3
*.db

# Benchmark/eval outputs: keep curated CSVs + plots; ignore stray logs, but DO keep the
# M4a sweep's per-cell raw logs (the audit trail behind sweep.csv -- perplexity stderr,
# per-chunk ppl series, llama.cpp build hash, /usr/bin/time -v that the CSV omits; 148 KB).
results/raw/
*.log
!results/sweep/raw/*.log

# M4b eval: keep the structured run data -- raw rows + frozen judge caches -- in the
# repo for reproducibility (the scorecard/findings derive from them; ~3 MB total),
# alongside golden.jsonl, scorecard.md, ablations.png, findings.md, SOURCES.md.
# Ignore only the pre-curation draft and the regenerable binary vector stores.
results/evals/golden_draft.jsonl
results/evals/store_*.sqlite

# M4c optimize: keep optimize.csv + plots + leaderboard + findings, AND the per-cell raw
# tool logs (the audit trail behind optimize.csv -- llama-bench ± stderr + time -v the CSV
# omits), mirroring M4a. `.log` is globally ignored, so the kept logs need a negation.
!results/optimize/raw/*.log

# Environment / secrets
.env
*.local
secrets/

# Claude Code local settings (keep shared settings.json; ignore local overrides)
.claude/settings.local.json

# OS / editor cruft
.DS_Store
Thumbs.db
.idea/
.vscode/
